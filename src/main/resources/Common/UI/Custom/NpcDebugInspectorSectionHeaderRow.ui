$C = "Common.ui";

Group {
  LayoutMode: Top;
  Anchor: (Top: 4, Bottom: 2);

  Group {
    Anchor: (Height: 1, Bottom: 4);
    Background: #2f3b4f;
  }

  Group {
    LayoutMode: Left;
    Anchor: (Height: 28);

    Button #SectionToggleButton {
      LayoutMode: Left;
      FlexWeight: 1;
      Anchor: (Height: 28);
      Style: ButtonStyle(
        Default: (Background: (Color: #00000000)),
        Hovered: (Background: (Color: #ffffff10)),
        Pressed: (Background: (Color: #ffffff08))
      );

      Label #SectionToggleGlyph {
        Anchor: (Width: 20, Height: 28);
        Text: "v";
        Style: (
          FontSize: 14,
          RenderBold: true,
          TextColor: #d7dfeb,
          HorizontalAlignment: Center,
          VerticalAlignment: Center
        );
      }

      Label #SectionTitle {
        Anchor: (Left: 22, Right: 126, Height: 28);
        Text: "OVERVIEW";
        Style: (
          FontSize: 13,
          RenderBold: true,
          TextColor: #eff4fa,
          HorizontalAlignment: Start,
          VerticalAlignment: Center,
          RenderUppercase: true,
          LetterSpacing: 1
        );
      }

      Label #SectionCount {
        Anchor: (Right: 10, Width: 96, Height: 28);
        Text: "0 fields";
        Style: (
          FontSize: 11,
          TextColor: #a9bfd7,
          HorizontalAlignment: End,
          VerticalAlignment: Center
        );
      }
    }

    Button #SectionMoveButton {
      Anchor: (Width: 28, Height: 28);
      Style: ButtonStyle(
        Default: (Background: (Color: #00000000)),
        Hovered: (Background: (Color: #ffffff10)),
        Pressed: (Background: (Color: #ffffff08))
      );

      Group {
        LayoutMode: Middle;
        Anchor: (Full: 0);

        Group {
          LayoutMode: Top;
          Anchor: (Width: 12, Height: 10);

          Group {
            Anchor: (Height: 2, Bottom: 2);
            Background: #8f9eb3;
          }

          Group {
            Anchor: (Height: 2, Bottom: 2);
            Background: #8f9eb3;
          }

          Group {
            Anchor: (Height: 2);
            Background: #8f9eb3;
          }
        }
      }
    }
  }
}
