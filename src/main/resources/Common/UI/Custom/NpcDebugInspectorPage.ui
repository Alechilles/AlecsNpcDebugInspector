$C = "Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer #NpcDebugInspectorRoot {
    Anchor: (Width: 510, Height: 780);

    #Title {
      $C.@Title #NpcDebugInspectorTitle {
        @Text = "NPC Debug Inspector";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 10, Right: 10, Top: 8, Bottom: 12);

      Group #NpcDebugInspectorHeaderRow {
        Anchor: (Height: 46);

        Group #NpcDebugInspectorSubtitle {
          LayoutMode: Top;
          Anchor: (Left: 0, Top: 0, Right: 130, Height: 40);

          Group {
            LayoutMode: Left;
            Anchor: (Height: 18);

            Label #NpcDebugInspectorSubtitleUuidLabel {
              Anchor: (Height: 18);
              Text: "UUID:";
              Style: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #c3d5e8,
                HorizontalAlignment: Start,
                VerticalAlignment: Center
              );
            }

            Group {
              Anchor: (Width: 4);
            }

            Label #NpcDebugInspectorSubtitleUuidValue {
              Anchor: (Height: 18);
              FlexWeight: 1;
              Text: "";
              Style: (
                FontSize: 12,
                TextColor: #c3d5e8,
                HorizontalAlignment: Start,
                VerticalAlignment: Center
              );
            }
          }

          Group {
            Anchor: (Height: 2);
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 18);

            Label #NpcDebugInspectorSubtitleUtcLabel {
              Anchor: (Height: 18);
              Text: "UTC:";
              Style: (
                FontSize: 12,
                RenderBold: true,
                TextColor: #c3d5e8,
                HorizontalAlignment: Start,
                VerticalAlignment: Center
              );
            }

            Group {
              Anchor: (Width: 4);
            }

            Label #NpcDebugInspectorSubtitleUtcValue {
              Anchor: (Height: 18);
              FlexWeight: 1;
              Text: "";
              Style: (
                FontSize: 12,
                TextColor: #c3d5e8,
                HorizontalAlignment: Start,
                VerticalAlignment: Center
              );
            }
          }
        }

        $C.@SmallSecondaryTextButton #NpcDebugInspectorPinButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Pin NPC";
          @Anchor = (Right: 0, Top: 8, Width: 120, Height: 30);
        }
      }

      Label #NpcDebugInspectorPinHint {
        Anchor: (Top: 2, Height: 30);
        Text: "";
        Style: (
          FontSize: 11,
          TextColor: #b7c8dc,
          HorizontalAlignment: Start,
          VerticalAlignment: Start,
          Wrap: true
        );
      }

      Group #NpcDebugInspectorRefreshRow {
        LayoutMode: Left;
        Anchor: (Top: 4, Height: 32);
        Background: #23344c(0.70);
        Padding: (Left: 8, Right: 10, Top: 7, Bottom: 7);

        Label #NpcDebugInspectorRefreshLabel {
          Anchor: (Width: 190, Height: 18);
          Text: "Update Rate: 1000 ms (1.00s)";
          Style: (
            FontSize: 11,
            TextColor: #d9e7f6,
            HorizontalAlignment: Start,
            VerticalAlignment: Center
          );
        }

        FloatSliderNumberField #NpcDebugInspectorRefreshSlider {
          FlexWeight: 1;
          Anchor: (Height: 5, Right: 0);
          SliderStyle: $C.@DefaultSliderStyle;
          NumberFieldContainerAnchor: (Left: 12, Width: 48, Height: 16);
          NumberFieldStyle: (...$C.@DefaultInputFieldStyle, FontSize: 11, TextColor: #dce8f5);
          NumberFieldMaxDecimalPlaces: 0;
          Min: 150;
          Max: 2000;
          Step: 50;
          Value: 1000;
        }
      }

      Group #NpcDebugInspectorEventFilterRow {
        LayoutMode: Top;
        Anchor: (Top: 4, Height: 42);
        Background: #23344c(0.62);
        Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);

        Group {
          LayoutMode: Left;
          Anchor: (Height: 16);

          Label #NpcDebugInspectorEventFilterLabel {
            Anchor: (Width: 66, Height: 16);
            Text: "Events:";
            Style: (
              FontSize: 11,
              RenderBold: true,
              TextColor: #d9e7f6,
              HorizontalAlignment: Start,
              VerticalAlignment: Center
            );
          }

          $C.@CheckBox #NpcDebugInspectorFilterCore {
            Anchor: (Width: 16, Height: 16);
          }

          Label {
            Anchor: (Width: 50, Height: 16);
            Text: "Core";
            Style: (
              FontSize: 11,
              TextColor: #c3d5e8,
              HorizontalAlignment: Start,
              VerticalAlignment: Center
            );
          }

          $C.@CheckBox #NpcDebugInspectorFilterTargeting {
            Anchor: (Width: 16, Height: 16);
          }

          Label {
            Anchor: (Width: 58, Height: 16);
            Text: "Target";
            Style: (
              FontSize: 11,
              TextColor: #c3d5e8,
              HorizontalAlignment: Start,
              VerticalAlignment: Center
            );
          }

          $C.@CheckBox #NpcDebugInspectorFilterTimers {
            Anchor: (Width: 16, Height: 16);
          }

          Label {
            Anchor: (Width: 56, Height: 16);
            Text: "Timers";
            Style: (
              FontSize: 11,
              TextColor: #c3d5e8,
              HorizontalAlignment: Start,
              VerticalAlignment: Center
            );
          }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Top: 2, Height: 16);

          Group {
            Anchor: (Width: 66);
          }

          $C.@CheckBox #NpcDebugInspectorFilterAlarms {
            Anchor: (Width: 16, Height: 16);
          }

          Label {
            Anchor: (Width: 50, Height: 16);
            Text: "Alarms";
            Style: (
              FontSize: 11,
              TextColor: #c3d5e8,
              HorizontalAlignment: Start,
              VerticalAlignment: Center
            );
          }

          $C.@CheckBox #NpcDebugInspectorFilterNeeds {
            Anchor: (Width: 16, Height: 16);
          }

          Label {
            Anchor: (Width: 58, Height: 16);
            Text: "Needs";
            Style: (
              FontSize: 11,
              TextColor: #c3d5e8,
              HorizontalAlignment: Start,
              VerticalAlignment: Center
            );
          }

          $C.@CheckBox #NpcDebugInspectorFilterFlock {
            Anchor: (Width: 16, Height: 16);
          }

          Label {
            Anchor: (Width: 56, Height: 16);
            Text: "Flock";
            Style: (
              FontSize: 11,
              TextColor: #c3d5e8,
              HorizontalAlignment: Start,
              VerticalAlignment: Center
            );
          }
        }
      }

      $C.@PanelSeparatorFancy {
        @Anchor = (Top: 4, Bottom: 8);
      }

      Group #NpcDebugInspectorFieldViewport {
        Anchor: (Top: 2);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        KeepScrollPosition: true;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Right: 6);

        Group #NpcDebugInspectorFieldList {
          LayoutMode: Top;
          Anchor: (Bottom: 6);
        }
      }

      Group #NpcDebugInspectorFooter {
        LayoutMode: Right;
        Anchor: (Top: 10, Height: 32);

        $C.@SmallSecondaryTextButton #NpcDebugInspectorBackButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Back";
          @Anchor = (Width: 120, Height: 32);
        }

        Group #NpcDebugInspectorFooterGap {
          Anchor: (Width: 10);
        }

        $C.@SmallSecondaryTextButton #NpcDebugInspectorCloseButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Close";
          @Anchor = (Width: 120, Height: 32);
        }
      }
    }
  }
}
