$C = "Common.ui";

Group {
  LayoutMode: Top;
  Anchor: (Top: 2, Left: 0, Right: 0, Height: 42);
  Background: #23344c(0.62);
  Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);

  Group {
    LayoutMode: Left;
    Anchor: (Height: 16);

    Label #NpcDebugInspectorEventFilterLabel {
      Anchor: (Width: 66, Height: 16);
      Text: "Events:";
      Style: (
        FontSize: 11,
        RenderBold: true,
        TextColor: #d9e7f6,
        HorizontalAlignment: Start,
        VerticalAlignment: Center
      );
    }

    $C.@CheckBox #NpcDebugInspectorFilterCore {
      Anchor: (Width: 16, Height: 16);
    }

    Label {
      Anchor: (Width: 50, Height: 16);
      Text: "Core";
      Style: (
        FontSize: 11,
        TextColor: #c3d5e8,
        HorizontalAlignment: Start,
        VerticalAlignment: Center
      );
    }

    $C.@CheckBox #NpcDebugInspectorFilterTargeting {
      Anchor: (Width: 16, Height: 16);
    }

    Label {
      Anchor: (Width: 58, Height: 16);
      Text: "Target";
      Style: (
        FontSize: 11,
        TextColor: #c3d5e8,
        HorizontalAlignment: Start,
        VerticalAlignment: Center
      );
    }

    $C.@CheckBox #NpcDebugInspectorFilterTimers {
      Anchor: (Width: 16, Height: 16);
    }

    Label {
      Anchor: (Width: 56, Height: 16);
      Text: "Timers";
      Style: (
        FontSize: 11,
        TextColor: #c3d5e8,
        HorizontalAlignment: Start,
        VerticalAlignment: Center
      );
    }
  }

  Group {
    LayoutMode: Left;
    Anchor: (Top: 2, Height: 16);

    Group {
      Anchor: (Width: 66);
    }

    $C.@CheckBox #NpcDebugInspectorFilterAlarms {
      Anchor: (Width: 16, Height: 16);
    }

    Label {
      Anchor: (Width: 50, Height: 16);
      Text: "Alarms";
      Style: (
        FontSize: 11,
        TextColor: #c3d5e8,
        HorizontalAlignment: Start,
        VerticalAlignment: Center
      );
    }

    $C.@CheckBox #NpcDebugInspectorFilterNeeds {
      Anchor: (Width: 16, Height: 16);
    }

    Label {
      Anchor: (Width: 58, Height: 16);
      Text: "Needs";
      Style: (
        FontSize: 11,
        TextColor: #c3d5e8,
        HorizontalAlignment: Start,
        VerticalAlignment: Center
      );
    }

    $C.@CheckBox #NpcDebugInspectorFilterFlock {
      Anchor: (Width: 16, Height: 16);
    }

    Label {
      Anchor: (Width: 56, Height: 16);
      Text: "Flock";
      Style: (
        FontSize: 11,
        TextColor: #c3d5e8,
        HorizontalAlignment: Start,
        VerticalAlignment: Center
      );
    }
  }
}
