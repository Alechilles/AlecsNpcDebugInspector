$C = "Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer #NpcDebugRosterRoot {
    Anchor: (Width: 980, Height: 740);

    #Title {
      $C.@Title #NpcDebugRosterTitle {
        @Text = "NPC Debug Inspector - Linked Roster";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 10, Right: 6, Top: 8, Bottom: 10);

      Label #NpcDebugRosterSubtitle {
        Anchor: (Height: 22);
        Text: "Linked NPCs: 0";
        Style: (
          FontSize: 14,
          TextColor: #c4d2e1,
          HorizontalAlignment: Start,
          VerticalAlignment: Center
        );
      }

      Group #NpcDebugRosterFilterControls {
        Anchor: (Top: 6, Height: 34);
        LayoutMode: Left;

        $C.@SmallSecondaryTextButton #NpcDebugRosterFilterLoadedButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Loaded Only: Off";
          @Anchor = (Width: 170);
        }

        Group {
          Anchor: (Width: 8);
        }

        $C.@SmallSecondaryTextButton #NpcDebugRosterFilterFlockButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Same Flock: Off";
          @Anchor = (Width: 160);
        }

        Group {
          Anchor: (Width: 8);
        }

        TextField #NpcDebugRosterFilterQueryField {
          Style: $C.@DefaultInputFieldStyle;
          PlaceholderStyle: $C.@DefaultInputFieldPlaceholderStyle;
          Background: $C.@InputBoxBackground;
          Anchor: (Width: 260, Height: 30);
          Padding: (Horizontal: 10);
          PlaceholderText: "Name/state contains...";
          MaxLength: 48;
        }

        Group {
          Anchor: (Width: 8);
        }

        $C.@SmallSecondaryTextButton #NpcDebugRosterApplyFilterButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Apply";
          @Anchor = (Width: 90);
        }

        Group {
          Anchor: (Width: 8);
        }

        $C.@SmallSecondaryTextButton #NpcDebugRosterClearFilterButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Clear";
          @Anchor = (Width: 90);
        }
      }

      $C.@PanelSeparatorFancy {
        @Anchor = (Top: 8, Bottom: 8);
      }

      Label #NpcDebugRosterEmpty {
        Anchor: (Top: 8, Height: 48);
        Text: "No linked NPCs yet. Use the inspector item on an NPC to link it.";
        Style: (
          FontSize: 14,
          TextColor: #b2c3d6,
          HorizontalAlignment: Start,
          VerticalAlignment: Start
        );
        Visible: false;
      }

      Group #NpcDebugRosterListViewport {
        Anchor: (Top: 1);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        KeepScrollPosition: true;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Left: 7, Right: 2, Top: 1, Bottom: 7);

        Group #NpcDebugRosterList {
          LayoutMode: Top;
          Anchor: (Bottom: 6);
        }
      }

      Group {
        LayoutMode: Right;

        $C.@SmallSecondaryTextButton #NpcDebugRosterCloseButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Close";
          @Anchor = (MinWidth: 140);
        }
      }
    }
  }
}
