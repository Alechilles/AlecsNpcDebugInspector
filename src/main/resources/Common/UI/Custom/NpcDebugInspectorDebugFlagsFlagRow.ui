$C = "Common.ui";

Group {
  Anchor: (Top: 2, Left: 0, Right: 0, Height: 56);
  Background: #23344c(0.86);
  Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);

  Label #FlagName {
    Anchor: (Left: 0, Top: 0, Right: 34, Height: 17);
    Text: "Flag Name";
    Style: (
      FontSize: 13,
      RenderBold: true,
      TextColor: #e7f0fb,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #FlagDescription {
    Anchor: (Left: 0, Top: 20, Right: 34, Height: 18);
    Text: "";
    Style: (
      FontSize: 11,
      TextColor: #b7c8dc,
      HorizontalAlignment: Start,
      VerticalAlignment: Start,
      Wrap: true
    );
  }

  $C.@CheckBox #FlagToggleCheck {
    Anchor: (Right: 0, Top: 9, Width: 22, Height: 22);
  }
}
