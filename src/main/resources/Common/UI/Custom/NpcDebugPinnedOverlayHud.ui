Group #NpcDebugPinnedOverlayRoot {
  Anchor: (Right: 18, Top: 95, Width: 420, Height: 540);
  Padding: (Left: 10, Right: 10, Top: 10, Bottom: 10);
  Background: (TexturePath: "Common/ContainerPanelPatch.png", Border: 4);
  Visible: true;

  Label #NpcDebugPinnedOverlayTitle {
    Anchor: (Top: 0, Left: 0, Right: 0, Height: 22);
    Text: "NPC Debug Pinned Overlay";
    Style: (
      FontSize: 15,
      RenderBold: true,
      TextColor: #eff4fa,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #NpcDebugPinnedOverlaySubtitle {
    Anchor: (Top: 24, Left: 0, Right: 0, Height: 18);
    Text: "";
    Style: (
      FontSize: 11,
      TextColor: #b7c8dc,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #NpcDebugPinnedOverlayBody {
    Anchor: (Top: 46, Left: 0, Right: 0, Bottom: 0);
    Text: "";
    Style: (
      FontSize: 12,
      TextColor: #e7f0fb,
      HorizontalAlignment: Start,
      VerticalAlignment: Start,
      Wrap: true
    );
  }
}
