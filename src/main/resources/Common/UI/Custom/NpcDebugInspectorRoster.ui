$C = "Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer #NpcDebugRosterRoot {
    Anchor: (Width: 600, Height: 740);

    #Title {
      $C.@Title #NpcDebugRosterTitle {
        @Text = "NPC Debug Inspector - Linked Roster";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 10, Right: 6, Top: 8, Bottom: 10);

      Group #NpcDebugRosterStatusRow {
        Anchor: (Height: 22);
        LayoutMode: Left;

        Label #NpcDebugRosterSubtitle {
          Anchor: (Height: 22);
          FlexWeight: 1;
          Text: "Linked NPCs: 0";
          Style: (
            FontSize: 14,
            TextColor: #c4d2e1,
            HorizontalAlignment: Start,
            VerticalAlignment: Center
          );
        }

        Label #NpcDebugRosterGameTimePausedWarning {
          Anchor: (Width: 240, Height: 22);
          Text: "WARNING: GAME TIME IS PAUSED";
          Style: (
            FontSize: 12,
            RenderBold: true,
            TextColor: #ffcd73,
            HorizontalAlignment: End,
            VerticalAlignment: Center
          );
          Visible: false;
        }
      }

      Group #NpcDebugRosterFilterControls {
        Anchor: (Top: 6, Height: 34);
        LayoutMode: Left;

        TextField #NpcDebugRosterFilterQueryField {
          Style: $C.@DefaultInputFieldStyle;
          PlaceholderStyle: $C.@DefaultInputFieldPlaceholderStyle;
          Background: $C.@InputBoxBackground;
          Anchor: (Width: 360, Height: 30);
          Padding: (Horizontal: 10);
          PlaceholderText: "Name/state contains...";
          MaxLength: 48;
        }

        Group {
          Anchor: (Width: 8);
        }

        $C.@SmallSecondaryTextButton #NpcDebugRosterApplyFilterButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Apply";
          @Anchor = (Width: 90);
        }

        Group {
          Anchor: (Width: 8);
        }

        $C.@SmallSecondaryTextButton #NpcDebugRosterClearFilterButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Clear";
          @Anchor = (Width: 90);
        }
      }

      Group #NpcDebugRosterCopyRow {
        Anchor: (Top: 3, Height: 30);
        LayoutMode: Left;
        Visible: false;

        Label #NpcDebugRosterCopyLabel {
          Anchor: (Width: 88, Height: 30);
          Text: "Copy Buffer:";
          Style: (
            FontSize: 12,
            TextColor: #c4d2e1,
            HorizontalAlignment: Start,
            VerticalAlignment: Center
          );
        }

        TextField #NpcDebugRosterCopyField {
          Style: $C.@DefaultInputFieldStyle;
          PlaceholderStyle: $C.@DefaultInputFieldPlaceholderStyle;
          Background: $C.@InputBoxBackground;
          Anchor: (Width: 292, Height: 30);
          Padding: (Horizontal: 10);
          PlaceholderText: "UUID appears here after pressing Copy UUID";
          MaxLength: 64;
        }

        Group {
          Anchor: (Width: 8);
        }

        Label #NpcDebugRosterCopyHint {
          Anchor: (Width: 180, Height: 30);
          Text: "Select field, then press Ctrl+C";
          Style: (
            FontSize: 11,
            TextColor: #a9bfd7,
            HorizontalAlignment: Start,
            VerticalAlignment: Center
          );
        }
      }

      $C.@PanelSeparatorFancy {
        @Anchor = (Top: 8, Bottom: 8);
      }

      Label #NpcDebugRosterEmpty {
        Anchor: (Top: 8, Height: 48);
        Text: "No linked NPCs yet. Use the inspector item on an NPC to link it.";
        Style: (
          FontSize: 14,
          TextColor: #b2c3d6,
          HorizontalAlignment: Start,
          VerticalAlignment: Start
        );
        Visible: false;
      }

      Group #NpcDebugRosterListViewport {
        Anchor: (Top: 1);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        KeepScrollPosition: true;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Left: 7, Right: 2, Top: 1, Bottom: 7);

        Group #NpcDebugRosterList {
          LayoutMode: Top;
          Anchor: (Bottom: 6);
        }
      }

      Group {
        LayoutMode: Right;

        $C.@SmallSecondaryTextButton #NpcDebugRosterCloseButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Close";
          @Anchor = (MinWidth: 140);
        }
      }
    }
  }
}
