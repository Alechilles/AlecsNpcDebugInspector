$C = "Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer #NpcDebugFlagsRoot {
    Anchor: (Width: 460, Height: 760);

    #Title {
      $C.@Title #NpcDebugFlagsTitle {
        @Text = "NPC Debug Inspector - Debug Flags";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 10, Right: 10, Top: 8, Bottom: 10);

      Label #NpcDebugFlagsSubtitle {
        Anchor: (Height: 22);
        Text: "";
        Style: (
          FontSize: 13,
          TextColor: #c3d5e8,
          HorizontalAlignment: Start,
          VerticalAlignment: Center
        );
      }

      Label #NpcDebugFlagsStatus {
        Anchor: (Top: 2, Height: 20);
        Text: "";
        Style: (
          FontSize: 11,
          TextColor: #b7c8dc,
          HorizontalAlignment: Start,
          VerticalAlignment: Center
        );
      }

      Group #NpcDebugFlagsPresetRow {
        LayoutMode: Left;
        Anchor: (Top: 4, Height: 34);

        $C.@SmallSecondaryTextButton #NpcDebugFlagsPresetAllButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Enable All";
          @Anchor = (Width: 142);
        }

        Group {
          Anchor: (Width: 8);
        }

        $C.@SmallSecondaryTextButton #NpcDebugFlagsPresetNoneButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Disable All";
          @Anchor = (Width: 142);
        }
      }

      $C.@PanelSeparatorFancy {
        @Anchor = (Top: 6, Bottom: 8);
      }

      Group #NpcDebugFlagsListViewport {
        Anchor: (Top: 2);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        KeepScrollPosition: true;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Right: 6, Bottom: 4);

        Group #NpcDebugFlagsList {
          LayoutMode: Top;
          Anchor: (Bottom: 6);
        }
      }

      Group #NpcDebugFlagsFooter {
        LayoutMode: Right;
        Anchor: (Top: 10, Height: 32);

        $C.@SmallSecondaryTextButton #NpcDebugFlagsBackButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Back";
          @Anchor = (Width: 120, Height: 32);
        }

        Group {
          Anchor: (Width: 10);
        }

        $C.@SmallSecondaryTextButton #NpcDebugFlagsCloseButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Close";
          @Anchor = (Width: 120, Height: 32);
        }
      }
    }
  }
}
