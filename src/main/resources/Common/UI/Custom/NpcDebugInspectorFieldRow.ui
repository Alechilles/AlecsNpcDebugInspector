$C = "Common.ui";

Group {
  Anchor: (Top: 2, Left: 0, Right: 0, Height: 30);
  Background: (TexturePath: "Common/ContainerPanelPatch.png", Border: 4);
  Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);

  Label #FieldChanged {
    Anchor: (Left: 0, Top: 1, Width: 18, Height: 18);
    Text: ">>";
    Visible: false;
    Style: (
      FontSize: 12,
      RenderBold: true,
      TextColor: #f5d59f,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #FieldText {
    Anchor: (Left: 20, Right: 30, Height: 18);
    Text: "";
    Style: (
      FontSize: 12,
      TextColor: #e7f0fb,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  $C.@CheckBox #FieldCheck {
    Anchor: (Right: 0, Top: -1, Width: 22, Height: 22);
    Visible: false;
  }
}
