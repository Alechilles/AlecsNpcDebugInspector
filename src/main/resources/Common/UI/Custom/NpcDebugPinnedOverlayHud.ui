$C = "Common.ui";

$C.@DecoratedContainer #NpcDebugPinnedOverlayRoot {
  Anchor: (Right: 18, Top: 95, Width: 420, Height: 540);

  #Title {
    $C.@Title #NpcDebugPinnedOverlayTitle {
      @Text = "NPC DEBUG PINNED OVERLAY";
    }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Left: 10, Right: 10, Top: 8, Bottom: 10);
    Background: #0d1b2e;

    Label #NpcDebugPinnedOverlaySubtitle {
      Anchor: (Height: 18);
      Text: "";
      Style: (
        FontSize: 11,
        TextColor: #b7c8dc,
        HorizontalAlignment: Start,
        VerticalAlignment: Center
      );
    }

    $C.@PanelSeparatorFancy {
      @Anchor = (Top: 5, Bottom: 7);
    }

    Group #NpcDebugPinnedOverlayBodyViewport {
      Anchor: (Top: 2);
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      KeepScrollPosition: true;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Padding: (Right: 6);

      Label #NpcDebugPinnedOverlayBody {
        Anchor: (Left: 0, Right: 0, Top: 0);
        Text: "";
        Style: (
          FontSize: 12,
          TextColor: #e7f0fb,
          HorizontalAlignment: Start,
          VerticalAlignment: Start,
          Wrap: true
        );
      }
    }
  }
}
