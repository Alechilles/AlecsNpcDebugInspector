$C = "Common.ui";

Group {
  Anchor: (Top: 2, Left: 0, Right: 0, Height: 32);
  Background: #23344c(0.86);
  Padding: (Left: 8, Right: 8, Top: 5, Bottom: 5);

  Label #FieldChanged {
    Anchor: (Left: 0, Top: 1, Width: 20, Height: 18);
    Text: ">>";
    Visible: false;
    Style: (
      FontSize: 12,
      RenderBold: true,
      TextColor: #f5d59f,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #FieldText {
    Anchor: (Left: 20, Right: 32, Height: 18);
    Text: "";
    Style: (
      FontSize: 13,
      TextColor: #e7f0fb,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Group #FieldSplitRow {
    LayoutMode: Left;
    Anchor: (Left: 20, Right: 32, Height: 18);
    Visible: false;

    Label #FieldName {
      Anchor: (Height: 18);
      Text: "";
      Style: (
        FontSize: 13,
        RenderBold: true,
        TextColor: #e7f0fb,
        HorizontalAlignment: Start,
        VerticalAlignment: Center
      );
    }

    Label #FieldValue {
      Anchor: (Height: 18);
      FlexWeight: 1;
      Text: "";
      Style: (
        FontSize: 13,
        TextColor: #e7f0fb,
        HorizontalAlignment: Start,
        VerticalAlignment: Center
      );
    }
  }

  $C.@CheckBox #FieldCheck {
    Anchor: (Right: 2, Top: 0, Width: 22, Height: 22);
    Visible: false;
  }
}
