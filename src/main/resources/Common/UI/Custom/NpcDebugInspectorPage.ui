$C = "Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer #NpcDebugInspectorRoot {
    Anchor: (Width: 510, Height: 780);

    #Title {
      $C.@Title #NpcDebugInspectorTitle {
        @Text = "NPC Debug Inspector";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 10, Right: 10, Top: 8, Bottom: 12);

      Group #NpcDebugInspectorHeaderRow {
        Anchor: (Height: 32);

        Label #NpcDebugInspectorSubtitle {
          Anchor: (Left: 0, Top: 5, Right: 130, Height: 22);
          Text: "";
          Style: (
            FontSize: 13,
            TextColor: #c3d5e8,
            HorizontalAlignment: Start,
            VerticalAlignment: Center
          );
        }

        $C.@SmallSecondaryTextButton #NpcDebugInspectorPinButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Pin NPC";
          @Anchor = (Right: 0, Top: 0, Width: 120, Height: 30);
        }
      }

      Label #NpcDebugInspectorPinHint {
        Anchor: (Top: 4, Height: 20);
        Text: "";
        Style: (
          FontSize: 11,
          TextColor: #b7c8dc,
          HorizontalAlignment: Start,
          VerticalAlignment: Center
        );
      }

      Group #NpcDebugInspectorRefreshRow {
        LayoutMode: Left;
        Anchor: (Top: 4, Height: 32);
        Background: #23344c(0.70);
        Padding: (Left: 8, Right: 10, Top: 7, Bottom: 7);

        Label #NpcDebugInspectorRefreshLabel {
          Anchor: (Width: 190, Height: 18);
          Text: "Update Rate: 1000 ms (1.00s)";
          Style: (
            FontSize: 11,
            TextColor: #d9e7f6,
            HorizontalAlignment: Start,
            VerticalAlignment: Center
          );
        }

        FloatSliderNumberField #NpcDebugInspectorRefreshSlider {
          FlexWeight: 1;
          Anchor: (Height: 5, Right: 0);
          SliderStyle: $C.@DefaultSliderStyle;
          NumberFieldContainerAnchor: (Left: 12, Width: 48, Height: 16);
          NumberFieldStyle: (...$C.@DefaultInputFieldStyle, FontSize: 11, TextColor: #dce8f5);
          NumberFieldMaxDecimalPlaces: 0;
          Min: 150;
          Max: 2000;
          Step: 50;
          Value: 1000;
        }
      }

      $C.@PanelSeparatorFancy {
        @Anchor = (Top: 4, Bottom: 8);
      }

      Group #NpcDebugInspectorFieldViewport {
        Anchor: (Top: 2);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        KeepScrollPosition: true;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Right: 6);

        ReorderableList #NpcDebugInspectorFieldList {
          LayoutMode: Top;
          Anchor: (Bottom: 6);
        }
      }

      Group {
        LayoutMode: Right;

        $C.@SmallSecondaryTextButton #NpcDebugInspectorCloseButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Close";
          @Anchor = (MinWidth: 120);
        }
      }
    }
  }
}
