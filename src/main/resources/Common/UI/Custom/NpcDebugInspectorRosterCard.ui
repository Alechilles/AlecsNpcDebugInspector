$C = "Common.ui";

@RosterRemoveIconButtonLabelStyle = LabelStyle(
  FontSize: 1,
  TextColor: #00000000
);

@RosterRemoveIconButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "NpcDebugInspector/LinkedPanelRemoveButton_Default.png"), LabelStyle: @RosterRemoveIconButtonLabelStyle),
  Hovered: (Background: (TexturePath: "NpcDebugInspector/LinkedPanelRemoveButton_Hover.png"), LabelStyle: @RosterRemoveIconButtonLabelStyle),
  Pressed: (Background: (TexturePath: "NpcDebugInspector/LinkedPanelRemoveButton_Pressed.png"), LabelStyle: @RosterRemoveIconButtonLabelStyle),
  Disabled: (Background: (TexturePath: "NpcDebugInspector/LinkedPanelRemoveButton_Disabled.png"), LabelStyle: @RosterRemoveIconButtonLabelStyle),
  Sounds: $C.@ButtonSounds
);

@RosterActionTooltipStyle = TextTooltipStyle(
  Background: #0f1e30(0.96),
  MaxWidth: 220,
  LabelStyle: (
    Wrap: true,
    FontSize: 14,
    TextColor: #eef4fb
  ),
  Padding: 12
);

Group {
  Anchor: (Top: 3, Left: 0, Right: 0, Height: 156);
  Background: (TexturePath: "Common/ContainerPanelPatch.png", Border: 4);
  Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);

  Label #CardName {
    Anchor: (Top: 0, Left: 0, Right: 260, Height: 22);
    Text: "NPC";
    Style: (
      FontSize: 16,
      RenderBold: true,
      TextColor: #eff4fa,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardUuid {
    Anchor: (Top: 22, Left: 0, Right: 260, Height: 16);
    Text: "UUID:";
    Style: (
      FontSize: 11,
      TextColor: #b7c8dc,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardRole {
    Anchor: (Top: 40, Left: 0, Right: 260, Height: 16);
    Text: "Role:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardStatus {
    Anchor: (Top: 58, Left: 0, Width: 170, Height: 16);
    Text: "Status:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardHealth {
    Anchor: (Top: 58, Left: 178, Width: 120, Height: 16);
    Text: "Health:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardState {
    Anchor: (Top: 76, Left: 0, Width: 170, Height: 16);
    Text: "State:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardFlock {
    Anchor: (Top: 76, Left: 178, Width: 120, Height: 16);
    Text: "Flock:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardLocation {
    Anchor: (Top: 94, Left: 0, Width: 170, Height: 16);
    Text: "Location:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardDistance {
    Anchor: (Top: 94, Left: 178, Width: 120, Height: 16);
    Text: "Distance:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardChange {
    Anchor: (Top: 112, Left: 0, Width: 170, Height: 16);
    Text: "";
    Style: (
      FontSize: 12,
      TextColor: #f5d59f,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardHighlightState {
    Anchor: (Top: 112, Left: 178, Width: 120, Height: 16);
    Text: "";
    Style: (
      FontSize: 12,
      TextColor: #c0e8ff,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Group #CardActionButtonsTop {
    Anchor: (Top: 48, Right: 0, Width: 248, Height: 30);
    LayoutMode: Left;

    $C.@SmallSecondaryTextButton #InspectButton {
      @Sounds = $C.@ButtonSounds;
      @Text = "Inspect";
      @Anchor = (Width: 120);
    }

    Group {
      Anchor: (Width: 8);
    }

    $C.@SmallSecondaryTextButton #DebugFlagsButton {
      @Sounds = $C.@ButtonSounds;
      @Text = "Debug Flags";
      @Anchor = (Width: 120);
    }
  }

  Group #CardActionButtonsBottom {
    Anchor: (Top: 86, Right: 0, Width: 248, Height: 30);
    LayoutMode: Left;

    $C.@SmallSecondaryTextButton #HighlightButton {
      @Sounds = $C.@ButtonSounds;
      @Text = "Highlight";
      @Anchor = (Width: 120);
    }

    Group {
      Anchor: (Width: 8);
    }

    $C.@SmallSecondaryTextButton #CopyButton {
      @Sounds = $C.@ButtonSounds;
      @Text = "Copy UUID";
      @Anchor = (Width: 120);
    }
  }

  TextButton #UnlinkButton {
    Anchor: (Top: 1, Right: 2, Width: 28, Height: 28);
    Style: @RosterRemoveIconButtonStyle;
    Text: "";
    TooltipText: "Unlink";
    TextTooltipStyle: @RosterActionTooltipStyle;
  }
}
