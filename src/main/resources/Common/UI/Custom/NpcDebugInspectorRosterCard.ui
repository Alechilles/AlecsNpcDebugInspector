$C = "Common.ui";

Group {
  Anchor: (Top: 3, Left: 0, Right: 0, Height: 152);
  Background: (TexturePath: "Common/ContainerPanelPatch.png", Border: 4);
  Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);

  Label #CardName {
    Anchor: (Top: 0, Left: 0, Width: 560, Height: 22);
    Text: "NPC";
    Style: (
      FontSize: 16,
      RenderBold: true,
      TextColor: #eff4fa,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardUuid {
    Anchor: (Top: 22, Left: 0, Width: 700, Height: 16);
    Text: "UUID:";
    Style: (
      FontSize: 11,
      TextColor: #b7c8dc,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardRole {
    Anchor: (Top: 40, Left: 0, Width: 700, Height: 16);
    Text: "Role:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardStatus {
    Anchor: (Top: 58, Left: 0, Width: 320, Height: 16);
    Text: "Status:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardState {
    Anchor: (Top: 76, Left: 0, Width: 420, Height: 16);
    Text: "State:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardHealth {
    Anchor: (Top: 58, Left: 330, Width: 200, Height: 16);
    Text: "Health:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardFlock {
    Anchor: (Top: 76, Left: 330, Width: 220, Height: 16);
    Text: "Flock:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardLocation {
    Anchor: (Top: 94, Left: 0, Width: 320, Height: 16);
    Text: "Location:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardDistance {
    Anchor: (Top: 94, Left: 330, Width: 220, Height: 16);
    Text: "Distance:";
    Style: (
      FontSize: 12,
      TextColor: #dbe6f2,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardChange {
    Anchor: (Top: 112, Left: 0, Width: 320, Height: 16);
    Text: "";
    Style: (
      FontSize: 12,
      TextColor: #f5d59f,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Label #CardHighlightState {
    Anchor: (Top: 112, Left: 330, Width: 220, Height: 16);
    Text: "";
    Style: (
      FontSize: 12,
      TextColor: #c0e8ff,
      HorizontalAlignment: Start,
      VerticalAlignment: Center
    );
  }

  Group #CardActionButtonsTop {
    Anchor: (Top: 48, Right: 0, Width: 338, Height: 30);
    LayoutMode: Right;

    $C.@SmallSecondaryTextButton #CopyButton {
      @Sounds = $C.@ButtonSounds;
      @Text = "Copy UUID";
      @Anchor = (Width: 118);
    }

    Group #CardActionSpacer {
      Anchor: (Width: 8);
    }

    $C.@SmallSecondaryTextButton #UnlinkButton {
      @Sounds = $C.@ButtonSounds;
      @Text = "Unlink";
      @Anchor = (Width: 90);
    }

    Group #CardActionSpacer2 {
      Anchor: (Width: 8);
    }

    $C.@SmallSecondaryTextButton #InspectButton {
      @Sounds = $C.@ButtonSounds;
      @Text = "Inspect";
      @Anchor = (Width: 114);
    }
  }

  Group #CardActionButtonsBottom {
    Anchor: (Top: 82, Right: 0, Width: 184, Height: 30);
    LayoutMode: Right;

    $C.@SmallSecondaryTextButton #DebugFlagsButton {
      @Sounds = $C.@ButtonSounds;
      @Text = "Debug Flags";
      @Anchor = (Width: 88);
    }

    Group {
      Anchor: (Width: 8);
    }

    $C.@SmallSecondaryTextButton #HighlightButton {
      @Sounds = $C.@ButtonSounds;
      @Text = "Highlight";
      @Anchor = (Width: 88);
    }
  }
}
